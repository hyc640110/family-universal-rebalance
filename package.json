{
  "name": "family-universal-rebalance",
  "version": "3.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "build:preview": "tsc -b && vite build --mode preview-deploy --outDir dist-preview",
    "test:stability": "node scripts/stability-check.mjs",
    "preview": "vite preview --host",
    "deploy": "npm run build && gh-pages -d dist",
    "deploy:preview": "npm run build:preview && gh-pages -d dist-preview -e preview -a -m \"Deploy preview\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "^1.24.0",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.18.1",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "gh-pages": "^6.3.0"
  }
}
