{
  "name": "family-universal-rebalance",
  "version": "4.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "check:environment-boundary:production": "node scripts/environment-boundary-check.mjs production",
    "check:environment-boundary:preview": "node scripts/environment-boundary-check.mjs preview",
    "check:environment-build-artifacts": "node scripts/environment-build-artifacts-check.mjs",
    "build": "npm run check:environment-boundary:production && tsc -b && vite build",
    "build:preview": "npm run check:environment-boundary:preview && tsc -b && vite build --mode preview-deploy --outDir dist-preview",
    "test:v6-0-1-environment-boundary": "tsx --test tests/environmentBoundary.test.ts && node --test tests/environmentBuildConfig.test.mjs",
    "test:financial-accounts": "tsx --test tests/financialAccounts.test.ts",
    "test:change-presentation": "tsx --test tests/changePresentation.test.ts",
    "test:v4-1": "npm run test:financial-accounts && npm run test:change-presentation",
    "test:transactions": "tsx --test tests/transactions.test.ts",
    "test:transaction-presentation": "tsx --test tests/transactionPresentation.test.ts",
    "test:import-center": "tsx --test tests/importCenter.test.ts",
    "test:v6-0-2-import-center": "tsx --test tests/importCenterConsolidation.test.ts",
    "test:v6-0-3-import-discoverability": "tsx --test tests/importCenterDiscoverability.test.ts",
    "test:v6-0-4-tool-navigation": "tsx --test tests/toolNavigationConsistency.test.ts",
    "test:v6-0-5-data-refresh-mobile-form-stability": "tsx --test tests/v6DataRefreshMobileFormStability.test.ts",
    "test:oauth-security": "tsx --test tests/oauthSecurity.test.ts",
    "test:v5-dashboard": "tsx --test tests/investmentDashboard.test.ts",
    "test:v5-1-performance": "tsx --test tests/investmentPerformanceHistory.test.ts",
    "test:v5-2-compact-assets": "tsx --test tests/compactAssetCards.test.ts",
    "test:v5-3-calendar": "tsx --test tests/dailyAssetChangeCalendar.test.ts",
    "test:quotes": "tsx --test tests/quoteMath.test.ts",
    "test:price-worker": "tsx --test tests/priceWorkerQuoteContract.test.ts",
    "test:v5-5-dividend": "tsx --test tests/dividends.test.ts",
    "test:v5-6-ai-decision": "tsx --test tests/aiDecision.test.ts tests/aiDecisionUiFoundation.test.ts",
    "test:v5-6-1a-sync-state": "tsx --test tests/syncState.test.ts",
    "test:v5-7-portfolio-risk": "tsx --test tests/portfolioRisk.test.ts",
    "test:v5-8-rebalance-recommendation": "tsx --test tests/rebalanceRecommendation.test.ts",
    "test:v5-8-1-allocation-presets": "tsx --test tests/allocationPresets.test.ts",
    "test:v5-9-investment-intelligence": "tsx --test tests/investmentIntelligence.test.ts",
    "test:v5-12-daily-decision-workflow": "tsx --test tests/dailyDecisionWorkflow.test.ts",
    "test:v5-13-investment-opportunities": "tsx --test tests/investmentOpportunities.test.ts",
    "test:v5-14-investment-action-center": "tsx --test tests/investmentActionCenter.test.ts",
    "test:v5-15-investment-action-explainability": "tsx --test tests/investmentActionExplainability.test.ts",
    "test:v5-10-clec-strategy": "tsx --test tests/clecStrategy.test.ts",
    "test:v6-2-clec-strategy-rules": "tsx --test tests/clecStrategyRules.test.ts",
    "test:v6-3-clec-rule-summary-bridge": "tsx --test tests/clecRuleSummaryPresentation.test.ts",
    "test:v6-4-allocation-context-clarity": "tsx --test tests/v6AllocationContextClarity.test.ts",
    "test:v6-5-quote-refresh-orchestration-boundary": "tsx --test tests/v6QuoteRefreshOrchestrationBoundary.test.ts",
    "test:v6-6-holding-quote-change-visibility": "tsx --test tests/v6HoldingQuoteChangeVisibility.test.ts",
    "test:v6-7-chart-readability-minimum-typography": "tsx --test tests/v6ChartReadabilityMinimumTypography.test.ts",
    "test:trend-chart-shared-axis": "tsx --test tests/trendChartSharedAxis.test.ts",
    "test:v6-13-typography-cascade-consistency": "tsx --test tests/v6TypographyCascadeConsistency.test.ts",
    "test:v6-8-rebalance-execution-eligibility": "tsx --test tests/rebalanceExecutionEligibility.test.ts",
    "test:v6-9-quote-refresh-freshness-consistency": "tsx --test tests/quoteMath.test.ts tests/v6QuoteRefreshFreshnessConsistency.test.ts",
    "test:tool-navigation": "tsx --test tests/toolNavigation.test.ts",
    "test:recommendations": "tsx --test tests/recommendations.test.ts",
    "test:v5-9-intelligence": "tsx --test tests/investmentIntelligence.test.ts tests/investmentIntelligenceAdapter.test.ts",
    "test:v5-10-4-sync-baseline": "tsx --test tests/syncBaseline.test.ts",
    "test:v5-10-4-1-production-regression": "tsx --test tests/productionSyncBaselineRegression.test.ts",
    "test:v5-10-4-2-transactions-regression": "tsx --test tests/productionTransactionsSyncRegression.test.ts",
    "test:runtime-provenance": "tsx --test tests/runtimeProvenance.test.ts",
    "test:market-worker-config": "node --test tests/marketWorkerEnvironmentConfig.test.mjs",
    "test:market-worker-runtime-parity": "node --test tests/marketWorkerRuntimeParity.test.mjs",
    "test:v5-4-market": "tsx --test tests/marketData.test.ts tests/marketUiFoundation.test.ts && node --test tests/marketDataWorker.test.mjs",
    "test:v6-10-market-refresh-data-update-consistency": "tsx --test tests/v6MarketRefreshDataUpdateConsistency.test.ts",
    "test:v6-10-1-market-refresh-cors-hotfix": "tsx --test tests/v6MarketRefreshCorsHotfix.test.ts",
    "test:v6-11-dividend-asset-reference-continuity": "tsx --test tests/dividendAssetReferences.test.ts",
    "check:market-worker-bundles": "node scripts/market-worker-bundle-check.mjs",
    "check:market-worker-preview-runtime": "node scripts/market-worker-runtime-contract-check.mjs preview",
    "check:market-worker-production-runtime": "node scripts/market-worker-runtime-contract-check.mjs production",
    "test:performance": "node scripts/performance-metrics-check.mjs",
    "test:cash-flow": "node scripts/cash-flow-check.mjs",
    "test:net-worth-history": "node scripts/net-worth-history-check.mjs",
    "test:stability": "npm run test:performance && npm run test:cash-flow && npm run test:net-worth-history && node scripts/stability-check.mjs",
    "preview": "vite preview --host",
    "deploy": "npm run build && gh-pages -d dist",
    "deploy:preview": "npm run build:preview && gh-pages -d dist-preview -e preview -a -m \"Deploy preview\"",
    "deploy:market-worker:preview": "wrangler deploy --config workers/market-data/wrangler.jsonc",
    "deploy:market-worker:production": "wrangler deploy --config workers/market-data/wrangler.production.jsonc"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "^1.24.0",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.18.1",
    "read-excel-file": "^9.3.1",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260713.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "gh-pages": "^6.3.0",
    "tsx": "^4.23.0",
    "wrangler": "^4.110.0"
  }
}
